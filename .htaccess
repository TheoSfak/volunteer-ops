# VolunteerOps - Root Security Rules

# Block access to sensitive file types
<FilesMatch "\.(sql|log|md|sh|bak|env|ini)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Block direct access to config.local.php
<Files "config.local.php">
    Order Deny,Allow
    Deny from all
</Files>

# Private uploads must be served only through authenticated PHP endpoints
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^uploads/(volunteer-docs|training/materials)/ - [F,L]
</IfModule>

# Block access to install.php after deployment
# Uncomment the following lines after installation is complete:
# <Files "install.php">
#     Order Deny,Allow
#     Deny from all
# </Files>

# Block hidden files (.git, .github, etc.)
<FilesMatch "^\.">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Disable directory listing
Options -Indexes

# Prevent MIME sniffing
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
